# --- Base de données Supabase (Prisma) ---
# URL "pooler" (port 6543, pgbouncer) pour l'app en serverless :
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# URL directe (port 5432) pour les migrations Prisma :
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# --- Mots de passe partagés (jamais côté client) ---
APP_PASSWORD="change-me"
MJ_PASSWORD="change-me-mj"

# --- Secret de signature des cookies de session (>= 32 caractères) ---
AUTH_SECRET="remplace-par-une-chaine-aleatoire-de-32-caracteres-minimum"

# --- Supabase Storage (upload des portraits) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service-role-key"

# --- URL publique du site (liens absolus des cartes de partage Open Graph) ---
# Optionnel : sur Vercel, VERCEL_PROJECT_PRODUCTION_URL sert de repli.
NEXT_PUBLIC_SITE_URL="https://cairn.exemple.com"
